@model Consulta_Medica.Models.ConsultaCrearViewModel

@{
    ViewData["Title"] = "Nueva Consulta Médica";
}

<div class="container mt-4">
    <form asp-action="Crear" id="consultaForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CitaId" />
        <input type="hidden" asp-for="PacienteId" />

        @* --- ENCABEZADO DE PACIENTE --- *@
        <div class="card shadow border-0 mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
                <h4 class="mb-0"><i class="bi bi-person-bounding-box me-2"></i>Atendiendo a: @Model.NombreCompletoPaciente</h4>
                <span class="badge bg-light text-primary px-3 py-2">
                    <i class="bi bi-calendar-event me-1"></i> @DateTime.Now.ToString("dd/MM/yyyy")
                </span>
            </div>
        </div>

        <div class="row">
            @* --- COLUMNA IZQUIERDA: DATOS CLÍNICOS --- *@
            <div class="col-lg-7">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body">
                        <h5 class="text-primary border-bottom pb-2 mb-3">
                            <i class="bi bi-file-earmark-medical me-2"></i>Información Clínica
                        </h5>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Fecha" class="form-label small fw-bold text-secondary"></label>
                                <input asp-for="Fecha" class="form-control border-primary-subtle" type="date" />
                                <span asp-validation-for="Fecha" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Motivo" class="form-label small fw-bold text-secondary"></label>
                                <textarea asp-for="Motivo" class="form-control border-primary-subtle" rows="2" placeholder="Describa el motivo de la visita..."></textarea>
                                <span asp-validation-for="Motivo" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Sintomas" class="form-label small fw-bold text-secondary"></label>
                                <textarea asp-for="Sintomas" class="form-control border-primary-subtle" rows="2" placeholder="Síntomas referidos por el paciente..."></textarea>
                            </div>

                            <div class="col-12">
                                <label asp-for="Diagnostico" class="form-label small fw-bold text-secondary"></label>
                                <textarea asp-for="Diagnostico" class="form-control border-primary-subtle bg-light" rows="3" placeholder="Diagnóstico definitivo o presuntivo..."></textarea>
                                <span asp-validation-for="Diagnostico" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="NotasEvolucion" class="form-label small fw-bold text-secondary"></label>
                                <textarea asp-for="NotasEvolucion" class="form-control border-primary-subtle" rows="2" placeholder="Notas adicionales o plan de tratamiento..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* --- COLUMNA DERECHA: LABORATORIO Y ACCIONES --- *@
            <div class="col-lg-5">
                @* Panel de Laboratorio *@
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-primary text-white">
                        <h6 class="mb-0"><i class="bi bi-flask me-2"></i>Indicaciones de Laboratorio</h6>
                    </div>
                    <div class="card-body">
                        <div class="input-group mb-3">
                            <input type="text" id="txtEstudio" class="form-control border-primary-subtle" placeholder="Nombre del estudio">
                            <button class="btn btn-outline-primary" type="button" id="btnAgregarEstudio">
                                <i class="bi bi-plus-circle"></i>
                            </button>
                        </div>
                        <input type="text" id="txtInstrucciones" class="form-control border-primary-subtle mb-3" placeholder="Instrucciones (opcional)">

                        <div class="table-responsive">
                            <table class="table table-sm" id="tablaEstudios">
                                <thead class="table-light">
                                    <tr>
                                        <th class="small">Estudio</th>
                                        <th class="small">Instrucciones</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @* Se llenará con JS *@
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                @* Acciones Finales *@
                <div class="card shadow-sm border-0 bg-primary-subtle">
                    <div class="card-body">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="GenerarReceta">
                            <label class="form-check-label fw-bold text-primary" asp-for="GenerarReceta">
                                <i class="bi bi-capsule me-1"></i> Ir a Receta al finalizar
                            </label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow">
                                <i class="bi bi-check2-circle me-1"></i> Guardar Consulta
                            </button>
                            <a asp-controller="Citas" asp-action="Index" class="btn btn-outline-secondary">
                                Cancelar
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let contadorEstudio = 0;

        document.getElementById("btnAgregarEstudio").addEventListener("click", function() {
            const estudio = document.getElementById("txtEstudio").value;
            const instrucciones = document.getElementById("txtInstrucciones").value;

            if (!estudio) {
                alert("Debe escribir el nombre del estudio.");
                return;
            }

            const tabla = document.getElementById("tablaEstudios").getElementsByTagName('tbody')[0];
            const nuevaFila = tabla.insertRow();

            nuevaFila.innerHTML = `
                <td class="small">
                    <input type="hidden" name="Indicaciones[${contadorEstudio}].NombreEstudio" value="${estudio}" />
                    ${estudio}
                </td>
                <td class="small text-muted">
                    <input type="hidden" name="Indicaciones[${contadorEstudio}].Instrucciones" value="${instrucciones}" />
                    ${instrucciones}
                </td>
                <td class="text-end">
                    <button type="button" class="btn btn-sm btn-outline-danger border-0" onclick="eliminarFila(this)">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            `;

            contadorEstudio++;
            document.getElementById("txtEstudio").value = "";
            document.getElementById("txtInstrucciones").value = "";
            document.getElementById("txtEstudio").focus();
        });

        function eliminarFila(btn) {
            btn.closest('tr').remove();
            // Nota: En un sistema real, conviene re-indexar los nombres de los inputs si se eliminan filas
        }
    </script>
}