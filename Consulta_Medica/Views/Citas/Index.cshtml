@model IEnumerable<Consulta_Medica.Models.CitaListaViewModel>

@{
    ViewData["Title"] = "Gestión de Citas";
}

<div class="container mt-4">
    @* Encabezado *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">
            <i class="bi bi-calendar-check me-2"></i>Gestión de Citas
        </h2>
        <a asp-action="Crear" class="btn btn-primary shadow-sm px-4">
            <i class="bi bi-calendar-plus me-1"></i> Registrar Nueva Cita
        </a>
    </div>

    @* Panel de Filtros *@
    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-secondary">Buscar Paciente</label>
                    <input type="text" name="buscarPaciente" class="form-control" placeholder="Nombre del paciente..." value="@ViewContext.HttpContext.Request.Query["buscarPaciente"]">
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-secondary">Médico</label>
                    <input type="text" name="buscarMedico" class="form-control" placeholder="Nombre del médico..." value="@ViewContext.HttpContext.Request.Query["buscarMedico"]">
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-secondary">Fecha</label>
                    <input type="date" name="fechaFiltro" class="form-control" value="@ViewContext.HttpContext.Request.Query["fechaFiltro"]">
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-search me-1"></i> Filtrar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-x-circle me-1"></i> Limpiar
                    </a>
                </div>
            </form>
        </div>
    </div>

    @* Tabla de Citas *@
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Citas Programadas</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 text-primary">Fecha y Hora</th>
                            <th class="text-primary">Paciente</th>
                            <th class="text-primary">Médico Asignado</th>
                            <th class="text-primary">Motivo</th>
                            <th class="text-primary">Estado</th>
                            <th class="text-center text-primary pe-4">Acciones Médicas</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-info-circle me-2"></i> No se encontraron citas con los filtros aplicados.
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 align-middle">
                                    <span class="fw-bold text-muted" style="font-size: 0.85rem;">
                                        @item.FechaHora.ToString("dd/MM/yyyy")
                                    </span>
                                    <span class="badge bg-info text-dark ms-1">@item.FechaHora.ToString("hh:mm tt")</span>
                                </td>
                                <td class="align-middle fw-semibold text-dark">@item.NombreCompletoPaciente</td>
                                <td class="align-middle">
                                    <span class="text-primary small fw-bold">
                                        <i class="bi bi-person-badge me-1"></i>@item.NombreCompletoMedico
                                    </span>
                                </td>
                                <td class="align-middle fw-semibold">@item.Motivo</td>
                                <td class="align-middle">
                                    <span class="badge rounded-pill border px-3
                                    @(item.EstadoCitaId == 1 ? "bg-primary-subtle text-primary border-primary-subtle" :
                                                    item.EstadoCitaId == 2 ? "bg-warning-subtle text-warning-emphasis border-warning-subtle" :
                                                    item.EstadoCitaId == 3 ? "bg-info-subtle text-info border-info-subtle" :
                                                    item.EstadoCitaId == 4 ? "bg-success-subtle text-success border-success-subtle" :
                                                    item.EstadoCitaId == 5 ? "bg-danger-subtle text-danger border-danger-subtle" :
                                                    item.EstadoCitaId == 6 ? "bg-secondary-subtle text-secondary border-secondary-subtle" :
                                                    "bg-light text-secondary")">
                                    <i class="bi bi-circle-fill me-1" style="font-size: 0.4rem;"></i>
                                    @item.EstadoCita
                                </span>
                            </td>
                            <td class="text-center pe-4 align-middle">
                                <div class="d-flex justify-content-center gap-2">
                                    @* Lógica Dinámica: Atender vs Ver Consulta *@
                                    @if (item.ConsultaId == null)
                                        {
                                            <a asp-controller="Consultas" asp-action="Crear" asp-route-citaId="@item.Id"
                                               class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm">
                                                <i class="bi bi-stethoscope me-1"></i> Atender
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-controller="Consultas" asp-action="Detalle" asp-route-id="@item.ConsultaId"
                                               class="btn btn-sm btn-success rounded-pill px-3 shadow-sm">
                                                <i class="bi bi-file-earmark-medical me-1"></i> Ver Consulta
                                            </a>
                                        }

                                        @* Botón de Gestión de Cita (Editar hora, médico, etc) *@
                                        <a asp-action="Detalle" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-secondary rounded-pill px-3 shadow-sm" title="Editar Cita">
                                            <i class="bi bi-gear"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>