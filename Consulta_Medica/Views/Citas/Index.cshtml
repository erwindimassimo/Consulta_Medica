@model IEnumerable<Consulta_Medica.Models.CitaListaViewModel>

@{
    ViewData["Title"] = "Citas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">
            <i class="bi bi-people-fill me-2"></i>Gestión de Citas
        </h2>
        <a asp-action="Crear" class="btn btn-primary shadow-sm px-4">
            <i class="bi bi-person-plus-fill me-1"></i> Registrar Nueva Cita
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Citas del día</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 text-primary">Fecha y hora</th>
                            <th class="text-primary">Nombre Completo</th>
                            <th class="text-primary">Motivo</th>
                            <th class="text-primary">Estado</th>
                            <th class="text-center text-primary pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                @* 1. HORA Y FECHA (Siguiendo tu formato de badge y separador) *@
                                <td class="ps-4 align-middle">
                                    <span class="badge bg-info text-dark">@item.FechaHora.ToString("hh:mm tt")</span>
                                    <span class="separador">:</span>
                                    <span class="ms-1 fw-bold text-muted" style="font-size: 0.85rem;">
                                        @item.FechaHora.ToString("dd/MM")
                                    </span>
                                </td>

                                @* 2. NOMBRE DEL PACIENTE *@
                                <td class="align-middle fw-semibold">@item.NombreCompleto</td>

                                @* 3. ESTADO Y MOTIVO (Adaptado de tu lógica de ARS) *@
                                <td class="align-middle">
                                    @if (item.EstadoCitaId == 1) // Supongamos 1 = Programada
                                    {
                                        <span class="text-primary"><i class="bi bi-calendar-event me-1"></i>@item.EstadoCita</span>
                                    }
                                    else if (item.EstadoCitaId == 2) // Supongamos 2 = En Espera/Llegó
                                    {
                                        <span class="text-warning fw-bold"><i class="bi bi-clock-history me-1"></i>@item.EstadoCita</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted italic">@item.EstadoCita</span>
                                    }
                                    <div class="text-muted" style="font-size: 0.75rem;">Modo: @item.Motivo</div>
                                </td>

                                @* 4. ACCIONES (Botón redondeado como el tuyo) *@
                                <td class="text-center pe-4 align-middle">
                                    <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="bi bi-pencil-square me-1"></i> Gestionar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
