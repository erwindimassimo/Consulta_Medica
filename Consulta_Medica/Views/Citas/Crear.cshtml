@model CitaCrearViewModel

@{
    ViewData["Title"] = "Agendar Cita";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="fas fa-calendar-plus mr-2"></i>Nueva Cita Médica</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Crear">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="PacienteId" class="form-label font-weight-bold">Paciente</label>
                        <select asp-for="PacienteId" class="form-control" asp-items="Model.Opciones.ListaPacientes">
                            <option value="">-- Seleccione el Paciente --</option>
                        </select>
                        <span asp-validation-for="PacienteId" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="FechaHora" class="form-label font-weight-bold"></label>
                        <input asp-for="FechaHora" class="form-control" type="datetime-local" />
                        <span asp-validation-for="FechaHora" class="text-danger"></span>
                    </div>
                    <div class="col-md-8 mb-3">
                        <label asp-for="Motivo" class="form-label font-weight-bold"></label>
                        <input asp-for="Motivo" class="form-control" placeholder="Ej: Chequeo Anual" />
                        <span asp-validation-for="Motivo" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Notas" class="form-label font-weight-bold"></label>
                    <textarea asp-for="Notas" class="form-control" rows="3" placeholder="Observaciones previas..."></textarea>
                </div>

                <hr />

                <div class="form-group d-flex justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary mr-2">
                        <i class="fas fa-arrow-left"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-save"></i> Agendar Cita
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>