@model IEnumerable<Consulta_Medica.Models.RecetaListaViewModel>

@{
    ViewData["Title"] = "Historial de Recetas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">
            <i class="bi bi-journal-medical me-2"></i>Historial de Recetas
        </h2>
        <a asp-action="Crear" class="btn btn-primary shadow-sm px-4">
            <i class="bi bi-plus-lg me-1"></i> Nueva Receta
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-secondary">Paciente</label>
                    <input type="text" name="buscarPaciente" class="form-control border-primary-subtle"
                           placeholder="Nombre o ID del paciente..." value="@Context.Request.Query["buscarPaciente"]">
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-secondary">Fecha</label>
                    <input type="date" name="fechaFiltro" class="form-control border-primary-subtle"
                           value="@(Context.Request.Query["fechaFiltro"].ToString() ?? DateTime.Today.ToString("yyyy-MM-dd"))">
                </div>
                <div class="col-md-5 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i> Filtrar Historial
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-clockwise me-1"></i> Limpiar
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="bi bi-list-check me-2"></i>Registro de Recetas</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 text-primary">Fecha receta</th>
                            <th class="text-primary">Paciente</th>
                            <th class="text-primary">Observaciones</th>
                            <th class="text-center text-primary pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bi bi-file-earmark-x display-4 text-primary opacity-25"></i>
                                        <p class="mt-2">No se encontraron recetas para los criterios seleccionados.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 align-middle">
                                    <span class="fw-bold text-dark">@item.FechaReceta.ToString("dd/MM/yyyy")</span>
                                </td>
                                <td class="align-middle">
                                    <div class="fw-semibold text-primary">@item.NombreCompletoPaciente</div>
                                    <small class="text-muted">ID: @item.PacienteIdentificacion</small>
                                </td>
                                <td class="align-middle">
                                    <span class="text-truncate d-inline-block text-secondary" style="max-width: 300px;" title="@item.Observaciones">
                                        @(string.IsNullOrEmpty(item.Observaciones) ? "Sin observaciones" : item.Observaciones)
                                    </span>
                                </td>
                                <td class="text-center pe-4 align-middle">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Ver Detalle">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <a asp-action="Imprimir" asp-route-id="@item.Id" target="_blank" class="btn btn-sm btn-outline-dark" title="Imprimir Receta">
                                            <i class="bi bi-printer-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>