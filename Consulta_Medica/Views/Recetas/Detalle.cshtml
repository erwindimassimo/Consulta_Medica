@model Consulta_Medica.Models.RecetaDetalleViewModel

@{
    ViewData["Title"] = "Detalle de Receta Médica";
}

<div class="container mt-4">
    <div class="card shadow border-0 overflow-hidden">
        <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-file-earmark-medical me-2"></i>Receta Médica #@Model.RecetaId</h4>
            <a asp-action="Index" class="btn btn-outline-light btn-sm shadow-sm">
                <i class="bi bi-arrow-left"></i> Volver al historial
            </a>
        </div>

        <div class="card-body p-4 p-lg-5">
            <div class="row mb-4">
                <div class="col-md-7">
                    <h6 class="text-primary fw-bold text-uppercase small mb-2">Información del Paciente</h6>
                    <h3 class="text-dark fw-bold mb-1">@Model.PacienteNombreCompleto</h3>
                    <p class="text-muted fs-5 mb-0">
                        <i class="bi bi-card-text text-primary me-2"></i>
                        <strong>Identificación:</strong> @Model.PacienteIdentificacion
                    </p>
                    @if (!string.IsNullOrEmpty(Model.SeguroMedico))
                    {
                        <p class="text-muted mb-0">
                            <i class="bi bi-shield-check text-primary me-2"></i>
                            <strong>ARS:</strong> @Model.SeguroMedico
                        </p>
                    }
                </div>
                <div class="col-md-5 text-md-end mt-3 mt-md-0">
                    <h6 class="text-primary fw-bold text-uppercase small mb-2">Fecha de Emisión</h6>
                    <h4 class="text-dark mb-1">@Model.FechaEmision.ToString("dd/MM/yyyy")</h4>
                </div>
            </div>

            <hr class="text-primary opacity-25" />

            <h5 class="mb-4 text-primary fw-bold">
                <i class="bi bi-capsule-pill me-2"></i>Medicamentos Prescritos
            </h5>

            <div class="table-responsive">
                <table class="table table-hover align-middle border">
                    <thead class="table-primary text-white">
                        <tr>
                            <th style="width: 35%">Medicamento / Laboratorio</th>
                            <th style="width: 25%">Presentación</th>
                            <th style="width: 40%">Indicaciones de Uso</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.LineasReceta)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark">@item.NombreMedicamento</div>
                                    <span class="badge bg-info text-dark opacity-75">@item.NombreLaboratorio</span>
                                </td>
                                <td>
                                    <div class="text-dark">@item.PresentacionComercial</div>
                                    <small class="text-muted">@item.ConcentracionDosis</small>
                                </td>
                                <td class="bg-light bg-opacity-50">
                                    <div class="p-2 border-start border-3 border-primary shadow-sm rounded">
                                        <i class="bi bi-info-circle text-primary me-2"></i>@item.Instrucciones
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!string.IsNullOrEmpty(Model.NotasMedicas))
            {
                <div class="mt-4 p-4 rounded-3 border-start border-4 border-primary bg-light shadow-sm">
                    <h6 class="fw-bold text-primary mb-2"><i class="bi bi-chat-left-text me-2"></i>Observaciones del Médico:</h6>
                    <p class="mb-0 text-dark italic">@Model.NotasMedicas</p>
                </div>
            }
        </div>

        <div class="card-footer bg-white py-4 text-end border-top-0">
            <button onclick="window.print();" class="btn btn-primary btn-lg px-5 shadow">
                <i class="bi bi-printer me-2"></i>Imprimir Receta
            </button>
        </div>
    </div>
</div>

<style>
    .table-primary {
        background-color: #0d6efd !important;
    }

    @@media print {
        .btn, .card-header a, .card-footer {
            display: none !important;
        }

        .card {
            border: none !important;
            box-shadow: none !important;
        }

        .container {
            width: 100% !important;
            max-width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        .table-primary {
            background-color: #0d6efd !important;
            color: white !important;
            -webkit-print-color-adjust: exact;
        }
    }
</style>