@model IEnumerable<Consulta_Medica.Models.PacienteListaViewModel>

@{
    ViewData["Title"] = "Pacientes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">
            <i class="bi bi-people-fill me-2"></i>Gestión de Pacientes
        </h2>
        <a asp-action="Crear" class="btn btn-primary shadow-sm px-4">
            <i class="bi bi-person-plus-fill me-1"></i> Registrar Nuevo Paciente
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Pacientes Activos</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 text-primary">Identificación</th>
                            <th class="text-primary">Nombre Completo</th>
                            <th class="text-center text-primary">Sexo</th> @* <-- Nueva Columna *@
                            <th class="text-primary">Seguro Médico / ARS</th>
                            <th class="text-center text-primary pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 align-middle">
                                    <span class="badge bg-info text-dark">@item.TipoIdentificacion</span>
                                    <span class="separador">:</span>
                                    <span class="ms-1 fw-bold text-nowrap">@item.Identificacion</span>
                                </td>
                                <td class="align-middle fw-semibold">@item.NombreCompleto</td>

                                @* Lógica visual para el Sexo *@
                                <td class="align-middle text-center">
                                    @if (item.Sexo == "Masculino")
                                    {
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill">
                                            <i class="bi bi-gender-male"></i> M
                                        </span>
                                    }
                                    else if (item.Sexo == "Femenino")
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill">
                                            <i class="bi bi-gender-female"></i> F
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary rounded-pill">
                                            <i class="bi bi-gender-ambiguous"></i> O
                                        </span>
                                    }
                                </td>

                                <td class="align-middle">
                                    @if (!string.IsNullOrEmpty(item.NombreARS) && item.NombreARS != "Particular" && item.NombreARS != "Privado")
                                    {
                                        <span class="text-primary"><i class="bi bi-shield-check me-1"></i>@item.NombreARS</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Privado / Particular</span>
                                    }
                                </td>
                                <td class="text-center pe-4 align-middle">
                                    <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="bi bi-eye-fill me-1"></i> Ver Ficha
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>