@model PacienteEditarViewModel

@{
    ViewData["Title"] = "Editar datos del paciente";
}

<div class="container mt-4">
    <form asp-action="Editar" method="post" id="formPaciente">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" id="datosContactosHidden" value='@Json.Serialize(Model.Opciones.ListaTiposContactos)' />

        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white py-3">
                <h3 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Editar Datos del Paciente</h3>
            </div>

            <div class="card-body p-4">
                @* Sección 1: Datos Personales *@
                <div class="row mb-4">
                    <div class="col-md-4">
                        <label asp-for="Nombres" class="form-label text-primary fw-bold small">Nombres</label>
                        <input asp-for="Nombres" class="form-control border-primary-subtle" required />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="PrimerApellido" class="form-label text-primary fw-bold small">Primer Apellido</label>
                        <input asp-for="PrimerApellido" class="form-control border-primary-subtle" required />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="SegundoApellido" class="form-label text-primary fw-bold small">Segundo Apellido</label>
                        <input asp-for="SegundoApellido" class="form-control border-primary-subtle" />
                    </div>
                </div>

                @* Sección 2: Identidad, Sexo y Fecha *@
                <div class="row mb-4">
                    <div class="col-md-3">
                        <label asp-for="TipoIdentificacionId" class="form-label text-primary fw-bold small">Tipo de Documento</label>
                        <select asp-for="TipoIdentificacionId" asp-items="Model.Opciones.ListaTiposIdentificaciones" class="form-select border-primary-subtle" id="cboTipoId">
                            <option value="">-- Seleccione --</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Identificacion" class="form-label text-primary fw-bold small">Número de Identidad</label>
                        <input asp-for="Identificacion" class="form-control border-primary-subtle" id="txtNumeroId" required />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="SexoId" class="form-label text-primary fw-bold small">Sexo</label>
                        <select asp-for="SexoId" asp-items="Model.Opciones.ListaSexos" class="form-select border-primary-subtle" required>
                            <option value="">-- Seleccione --</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="FechaNacimiento" class="form-label text-primary fw-bold small">Fecha de Nacimiento</label>
                        <input asp-for="FechaNacimiento" type="date" class="form-control border-primary-subtle" required />
                    </div>
                </div>

                @* Sección 3: Dirección *@
                <div class="row mb-4">
                    <div class="col-md-12">
                        <label asp-for="Direccion" class="form-label fw-bold text-primary small">Dirección completa</label>
                        <div class="input-group">
                            <span class="input-group-text bg-primary-subtle text-primary border-primary-subtle"><i class="bi bi-geo-alt"></i></span>
                            <textarea asp-for="Direccion" class="form-control border-primary-subtle" rows="2" placeholder="Calle, número, sector..."></textarea>
                        </div>
                    </div>
                </div>

                @* Sección 4: Seguro Médico *@
                <div class="bg-light p-3 rounded border-start border-4 border-primary mb-4 shadow-sm">
                    <h6 class="text-primary fw-bold mb-3">Seguro Médico</h6>
                    <div class="row">
                        <div class="col-md-6">
                            <label asp-for="ARSId" class="form-label small text-primary fw-bold">Aseguradora (ARS)</label>
                            <select asp-for="ARSId" asp-items="Model.Opciones.ListaARSs" class="form-select border-primary-subtle" id="cboArs" required>
                                <option value="">-- Seleccione --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NumeroAfiliacion" class="form-label small text-primary fw-bold">Número de Afiliación</label>
                            <input asp-for="NumeroAfiliacion" class="form-control border-primary-subtle" id="txtAfiliacion" />
                        </div>
                    </div>
                </div>

                @* Sección 5: Contactos *@
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center border-bottom border-primary pb-2 mb-3">
                            <h6 class="text-primary fw-bold mb-0"><i class="bi bi-telephone-plus me-2"></i>Información de Contacto</h6>
                            <button type="button" id="btnAgregarContacto" class="btn btn-sm btn-primary rounded-pill px-3">
                                <i class="bi bi-plus-circle me-1"></i> Añadir Contacto
                            </button>
                        </div>
                        <div id="contenedorContactos"></div>
                    </div>
                </div>
            </div>

            <div class="card-footer bg-white py-3 d-flex justify-content-between">
                <a asp-action="Detalle" asp-route-id="@Model.Id" class="btn btn-outline-primary px-4">
                    <i class="bi bi-arrow-left me-1"></i> Cancelar
                </a>
                <button type="submit" class="btn btn-primary px-5 shadow">Guardar Cambios</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // --- Variables de Estado y Datos de la Base de Datos ---
        let listaTiposContactos = [];
        let contadorContactos = 0;

        // "Memoria" para no perder los datos que ya están guardados
        const dataOriginal = {
            tipoId: "@Model.TipoIdentificacionId",
            identificacion: "@Model.Identificacion",
            arsId: "@Model.ARSId",
            afiliacion: "@Model.NumeroAfiliacion"
        };

        document.addEventListener("DOMContentLoaded", function () {
            // 1. Cargar Tipos de Contactos
            const inputHidden = document.getElementById('datosContactosHidden');
            if (inputHidden) listaTiposContactos = JSON.parse(inputHidden.value);

            // 2. Función de Gestión (Basada en tu vista Crear)
            const gestionar = (idCbo, idTxt, idFijo, valOriginal, idOriginal, placeholder) => {
                const cbo = document.getElementById(idCbo);
                const txt = document.getElementById(idTxt);

                if (cbo && txt) {
                    const refrescar = (esInicio) => {
                        const esBloqueado = cbo.value === idFijo;
                        txt.disabled = esBloqueado;

                        if (esBloqueado) {
                            txt.value = ""; // Borra el dato como en "Crear"
                            txt.placeholder = "No aplica";
                        } else {
                            // SI regresamos a la opción original de la BD, recuperamos el valor
                            if (cbo.value === idOriginal) {
                                txt.value = valOriginal;
                            } else if (!esInicio) {
                                // SI es una opción nueva y no es el inicio, limpiamos
                                txt.value = "";
                            }
                            txt.placeholder = placeholder;
                        }
                    };

                    cbo.addEventListener('change', () => refrescar(false));
                    refrescar(true); // Ejecución inicial
                }
            };

            // Aplicar reglas: ID "1" suele ser "Menor" y "Sin Seguro"
            gestionar('cboTipoId', 'txtNumeroId', "1", dataOriginal.identificacion, dataOriginal.tipoId, "Ingrese documento");
            gestionar('cboArs', 'txtAfiliacion', "1", dataOriginal.afiliacion, dataOriginal.arsId, "Número de carnet");

            // 3. Cargar Contactos Existentes
            const contactosExistentes = @Html.Raw(Json.Serialize(Model.Contactos ?? new List<ContactoViewModel>()));
            if (contactosExistentes && contactosExistentes.length > 0) {
                contactosExistentes.forEach((c, index) => agregarFilaContacto(c.tipoContactoId, c.valor, index === 0));
            } else {
                agregarFilaContacto("", "", true);
            }

            document.getElementById('btnAgregarContacto').onclick = () => agregarFilaContacto();
        });

        function agregarFilaContacto(tipoId = "", valor = "", esPrimero = false) {
            const contenedor = document.getElementById('contenedorContactos');
            const filasActuales = document.querySelectorAll('.contacto-item').length;
            if (filasActuales >= listaTiposContactos.length && tipoId === "") return;

            const div = document.createElement('div');
            div.className = 'row mb-3 align-items-center contacto-item animated fadeIn';

            let opcionesHtml = '<option value="">-- Seleccione --</option>';
            listaTiposContactos.forEach(tipo => {
                const seleccionado = tipo.value == tipoId ? 'selected' : '';
                opcionesHtml += `<option value="${tipo.value}" ${seleccionado}>${tipo.text}</option>`;
            });

            div.innerHTML = `
                <div class="col-md-4">
                    <select name="Contactos[${contadorContactos}].TipoContactoId" class="form-select border-primary-subtle sel-tipo" required>
                        ${opcionesHtml}
                    </select>
                </div>
                <div class="col-md-6">
                    <input name="Contactos[${contadorContactos}].Valor" value="${valor}" class="form-control border-primary-subtle input-valor" required placeholder="Dato de contacto..." />
                </div>
                <div class="col-md-2 text-end">
                    ${!esPrimero ? `<button type="button" class="btn btn-outline-danger border-0" onclick="this.closest('.contacto-item').remove()"><i class="bi bi-trash3-fill"></i></button>` :
                    '<span class="badge bg-primary-subtle text-primary border border-primary-subtle p-2">Principal</span>'}
                </div>
            `;
            contenedor.appendChild(div);
            contadorContactos++;
        }
    </script>
}